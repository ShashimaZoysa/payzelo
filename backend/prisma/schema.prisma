generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================
// ENUMS
// ==================

enum Role {
  ADMIN
  OWNER
  STAFF
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
}

enum RiskScore {
  GREEN
  YELLOW
  RED
}

enum QuotationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CONVERTED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  EZCASH
  CHEQUE
}

enum ActionType {
  CREATED_INVOICE
  RECORDED_PAYMENT
  CREATED_CUSTOMER
  CREATED_QUOTATION
  CONVERTED_QUOTATION
  UPDATED_CUSTOMER
  DELETED_CUSTOMER
  CREATED_STAFF
  UPDATED_INVOICE
  DELETED_INVOICE
  UPDATED_QUOTATION
  DELETED_QUOTATION
  UPDATED_BUSINESS
  SUSPENDED_BUSINESS
}

enum ReminderType {
  BEFORE_DUE
  ON_DUE
  OVERDUE_WEEK_1
  OVERDUE_WEEK_2
  OVERDUE_WEEK_3
}

enum ReminderStatus {
  PENDING
  DELIVERED
  FAILED
}

enum ReminderChannel {
  EMAIL
  SMS
  WHATSAPP
}

// ==================
// PLAN TABLE
// ==================

model Plan {
  id            String     @id @default(uuid())
  name          String     @unique
  customerLimit Int?
  isUnlimited   Boolean    @default(false)
  price         Float
  businesses    Business[]
}

// ==================
// CORE TABLES
// ==================

model Business {
  id                  String         @id @default(uuid())
  ownerUserId         String?
  name                String
  address             String?
  phone               String?
  email               String?
  logo                String?
  planId              String
  plan                Plan           @relation(fields: [planId], references: [id])
  status              BusinessStatus @default(ACTIVE)
  lastInvoiceNumber   Int            @default(0)
  lastQuotationNumber Int            @default(0)
  isDeleted           Boolean        @default(false)
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  users               User[]         @relation("BusinessUsers")
  owner               User?          @relation("BusinessOwner", fields: [ownerUserId], references: [id])
  customers           Customer[]
  quotations          Quotation[]
  invoices            Invoice[]
  auditLogs           AuditLog[]

  @@index([status])
}

model User {
  id                String      @id @default(uuid())
  businessId        String?
  business          Business?   @relation("BusinessUsers", fields: [businessId], references: [id])
  ownedBusinesses   Business[]  @relation("BusinessOwner")
  name              String
  email             String      @unique
  password          String
  role              Role        @default(STAFF)
  isDeleted         Boolean     @default(false)
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  customersCreated  Customer[]  @relation("CustomerCreatedBy")
  customersUpdated  Customer[]  @relation("CustomerUpdatedBy")
  quotationsCreated Quotation[] @relation("QuotationCreatedBy")
  quotationsUpdated Quotation[] @relation("QuotationUpdatedBy")
  invoicesCreated   Invoice[]   @relation("InvoiceCreatedBy")
  invoicesUpdated   Invoice[]   @relation("InvoiceUpdatedBy")
  payments          Payment[]
  auditLogs         AuditLog[]
}

model Customer {
  id              String      @id @default(uuid())
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id])
  name            String
  email           String?
  phone           String?
  address         String?
  riskScore       RiskScore   @default(GREEN)
  createdByUserId String
  createdBy       User        @relation("CustomerCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUserId String
  updatedBy       User        @relation("CustomerUpdatedBy", fields: [updatedByUserId], references: [id])
  isDeleted       Boolean     @default(false)
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  quotations      Quotation[]
  invoices        Invoice[]

  @@index([businessId])
}

model Quotation {
  id              String          @id @default(uuid())
  businessId      String
  business        Business        @relation(fields: [businessId], references: [id])
  customerId      String
  customer        Customer        @relation(fields: [customerId], references: [id])
  quotationNumber String
  customerName    String
  customerPhone   String?
  customerAddress String?
  subtotal        Float
  discount        Float           @default(0)
  tax             Float           @default(0)
  total           Float
  status          QuotationStatus @default(PENDING)
  expiryDate      DateTime?
  notes           String?
  createdByUserId String
  createdBy       User            @relation("QuotationCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUserId String
  updatedBy       User            @relation("QuotationUpdatedBy", fields: [updatedByUserId], references: [id])
  isDeleted       Boolean         @default(false)
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  items           QuotationItem[]
  invoice         Invoice?

  @@unique([businessId, quotationNumber])
  @@index([businessId])
  @@index([customerId])
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  name        String
  quantity    Float
  unitPrice   Float
  total       Float
}

model Invoice {
  id              String        @id @default(uuid())
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id])
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  quotationId     String?       @unique
  quotation       Quotation?    @relation(fields: [quotationId], references: [id])
  invoiceNumber   String
  customerName    String
  customerPhone   String?
  customerAddress String?
  subtotal        Float
  discount        Float         @default(0)
  tax             Float         @default(0)
  total           Float
  amountPaid      Float         @default(0)
  balance         Float
  dueDate         DateTime
  status          InvoiceStatus @default(UNPAID)
  notes           String?
  createdByUserId String
  createdBy       User          @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUserId String
  updatedBy       User          @relation("InvoiceUpdatedBy", fields: [updatedByUserId], references: [id])
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           InvoiceItem[]
  payments        Payment[]
  reminders       Reminder[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([businessId, status])
  @@index([businessId, dueDate])
  @@index([businessId, createdAt])
}

model InvoiceItem {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name      String
  quantity  Float
  unitPrice Float
  total     Float
}

model Payment {
  id                   String        @id @default(uuid())
  invoiceId            String
  invoice              Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount               Float
  paymentMethod        PaymentMethod @default(CASH)
  recordedByUserId     String
  recordedBy           User          @relation(fields: [recordedByUserId], references: [id])
  transactionReference String?
  chequeNumber         String?
  bankName             String?
  note                 String?
  isDeleted            Boolean       @default(false)
  deletedAt            DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([invoiceId])
}

model Reminder {
  id           String          @id @default(uuid())
  invoiceId    String
  invoice      Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reminderType ReminderType
  channel      ReminderChannel @default(EMAIL)
  status       ReminderStatus  @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime        @default(now())

  @@index([invoiceId])
}

model AuditLog {
  id         String     @id @default(uuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id])
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  action     ActionType
  details    String?
  createdAt  DateTime   @default(now())

  @@index([businessId])
  @@index([businessId, createdAt])
}